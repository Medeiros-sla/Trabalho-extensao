{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Stock item details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "imageUrl": { "type": "string" },
        "lowStockThreshold": { "type": "number" }
      },
      "required": ["name", "price", "quantity"]
    },
    "Client": {
      "title": "Client",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["name"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" }
      },
      "required": ["clientId", "items", "total", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "App user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "vendedor"] }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory of products"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Customer database"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales history"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    }
  }
}
