rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Connection Test ---
    // Publicly readable dummy path for healthchecks
    match /test/connection {
      allow read: if true;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Rule: Identity roles are only valid if user has correct profile claim
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getProfile().role == 'admin';
    }

    function isSeller() {
      return isSignedIn() && (getProfile().role == 'vendedor' || getProfile().role == 'admin');
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.email is string && data.email.size() > 0 &&
               (data.role == 'admin' || data.role == 'vendedor');
      }

      allow read: if isSignedIn();
      // Users can only write their own profile, and cannot escalate their own role unless they are already admin
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'vendedor';
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == existing().role && // Immortality: Role cannot be changed by user
                    incoming().email == existing().email;
      allow write: if isAdmin() && isValidUser(incoming());
    }

    // --- Products ---
    match /products/{productId} {
      function isValidProduct(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.price is number && data.price >= 0 &&
               data.quantity is number && data.quantity >= 0;
      }

      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // --- Clients ---
    match /clients/{clientId} {
      function isValidClient(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               (!('email' in data) || (data.email is string && data.email.size() <= 100));
      }

      allow read: if isSignedIn();
      allow create: if isSeller() && isValidClient(incoming());
      allow update: if isSeller() && isValidClient(incoming());
      allow delete: if isAdmin();
    }

    // --- Sales ---
    match /sales/{saleId} {
      function isValidSale(data) {
        return data.clientId is string && isValidId(data.clientId) &&
               data.items is list && data.items.size() > 0 &&
               data.total is number && data.total >= 0 &&
               data.createdAt == request.time; // Temporal Integrity
      }

      allow read: if isSignedIn();
      // Sellers can create sales. Sales are immutable.
      allow create: if isSeller() && isValidSale(incoming());
      allow update, delete: if isAdmin();
    }
  }
}
